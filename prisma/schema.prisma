// ─── HERMES AI AGENT ──────────────────────────────────────────

model HermesAgent {
  id                String   @id @default(cuid())
  companyId         String   @unique
  enabled           Boolean  @default(false) // App Owner enables Hermes for this tenant
  dataAccessEnabled Boolean  @default(false) // Tenant owner opts in to sharing accounting data
  personality       String   @default("professional") // professional | friendly | concise
  greeting          String?
  systemPrompt      String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // ─── Per-tenant rate limits (configurable from App Owner oversight page) ───
  // Defaults: 10/min burst, 40/hour, 120/day, 2000/month.
  // See Hermes AI Modelanbefalinger PDF §8.4 for rationale.
  // When rateLimitEnabled=false, all requests are allowed (no enforcement).
  rateLimitEnabled Boolean  @default(true)
  rateLimitBurst    Int      @default(10)    // max requests per minute (flood/script protection)
  rateLimitHour     Int      @default(40)    // max requests per hour
  rateLimitDay      Int      @default(120)   // max requests per day (fair-use quota)
  rateLimitMonth    Int      @default(2000)  // max requests per month (cost predictability)

  company   Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  reminders AgentReminder[]
  messages  AgentMessage[]
  skills    HermesAgentSkill[]
}

// ─── HERMES RAG KNOWLEDGE BASE (pgvector) ──────────────────────
// Stores documents + their chunked embeddings for semantic retrieval.
// Requires the `vector` extension on Neon:
//   CREATE EXTENSION IF NOT EXISTS vector;
//
// Documents can be:
//   - GLOBAL (tenantId = null): shared knowledge visible to all tenants
//     (e.g. AlphaFlow user manual, Danish tax rules, FAQ)
//   - TENANT-SPECIFIC (tenantId set): private notes for one company
//     (e.g. "This company uses a custom invoice template")
//
// Chunks are embedded via OpenAI text-embedding-3-small (1536 dims) or
// OpenRouter's free embedding models. The embedding column uses the
// pgvector `vector(1536)` type via Prisma's Unsupported type.
// --------------------------------------------------------------

model KnowledgeDocument {
  id          String   @id @default(cuid())
  title       String                       // Human-readable title (e.g. "AlphaFlow Brugsvejledning")
  source      String   @default("manual")  // manual | upload | url — how it was added
  category    String   @default("general") // general | manual | faq | tax-rules | tenant-note
  tenantId    String?                      // null = global; set = tenant-private note
  description String?                      // Optional description shown in admin UI
  content     String   @db.Text            // Full raw text (Markdown). Chunks are derived from this.
  chunkCount  Int      @default(0)         // Number of chunks currently embedded
  status      String   @default("active")  // active | processing | error | archived
  errorMessage String?                      // Populated when status='error'
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  chunks KnowledgeChunk[]

  @@index([tenantId])
  @@index([category])
  @@index([status])
}

model KnowledgeChunk {
  id         String   @id @default(cuid())
  documentId String
  chunkIndex Int                              // 0-based position within the document
  content    String  @db.Text                  // The chunk text (sent to LLM as context)
  // pgvector column — 1536 dims for OpenAI text-embedding-3-small.
  // Prisma doesn't natively support `vector`, so we use Unsupported("vector(1536)")
  // and read/write it via raw SQL in the knowledge-service.
  embedding  Unsupported("vector(1536)")?
  tokenCount Int      @default(0)              // Approximate token count of content
  createdAt  DateTime @default(now())

  document KnowledgeDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
}

// Enable vector similarity search via the <=> operator (cosine distance).
// The knowledge-service uses raw SQL for all embedding operations:
//   SELECT id, content FROM "KnowledgeChunk"
//   WHERE embedding <=> $1 < 0.5   -- cosine distance threshold
//   ORDER BY embedding <=> $1
//   LIMIT 5;

model AgentReminder {
  id          String    @id @default(cuid())
  agentId     String
  title       String
  description String?
  dueDate     DateTime?
  status      String    @default("pending") // pending | completed | dismissed
  createdAt   DateTime  @default(now())

  agent HermesAgent @relation(fields: [agentId], references: [id], onDelete: Cascade)
}

model AgentMessage {
  id        String   @id @default(cuid())
  agentId   String
  role      String // "user" | "assistant"
  content   String
  createdAt DateTime @default(now())

  agent HermesAgent @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@index([agentId, createdAt])
}

// ─── HERMES SKILLS (App Owner installs, tenants enable) ────────
// Skills inject instructions into the Hermes system prompt.
// SuperDev manages the skill catalog; each tenant can enable/disable.

model HermesSkill {
  id              String   @id @default(cuid())
  name            String   @unique        // e.g. "stop-slop"
  version         String   @default("1.0.0")
  descriptionEn   String                  // English description
  descriptionDa   String?                 // Danish description (falls back to en)
  author          String?
  sourceUrl       String?                 // e.g. GitHub URL
  // System prompt fragments — injected when the skill is active
  promptEn        String                  // English prompt fragment
  promptDa        String?                 // Danish prompt fragment (falls back to en)
  // Metadata
  enabledByDefault Boolean @default(false) // Auto-enabled for new tenants
  isBuiltIn       Boolean @default(false)  // Cannot be deleted (shipped with app)
  category        String   @default("writing") // writing | compliance | analysis | productivity
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  agentSkills HermesAgentSkill[]
}

model HermesAgentSkill {
  id        String   @id @default(cuid())
  agentId   String
  skillId   String
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  agent HermesAgent @relation(fields: [agentId], references: [id], onDelete: Cascade)
  skill HermesSkill @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([agentId, skillId])
}

// ─── NOTIFICATION READ STATE ──────────────────────────────────
// Tracks which in-app notifications a user has dismissed / read.
// This ensures read state syncs across devices and browser instances.

model NotificationRead {
  id             String   @id @default(cuid())
  userId         String
  notificationId String // Deterministic ID from the notification source (e.g. "overdue-abc123", "vat-deadline")
  readAt         DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, notificationId])
  @@index([userId])
  @@index([readAt])
}

// ─── RECEIVED E-INVOICES (FASE 3) ──────────────────────────────
// Stores incoming OIOUBL / Peppol BIS Billing 3.0 invoices and credit notes.
// Each record holds the raw XML, parsed data, and workflow status.

model ReceivedInvoice {
  id String @id @default(cuid())

  // Supplier (sender) information — extracted from XML
  supplierName    String
  supplierCvr     String? // CVR or VAT number
  supplierEmail   String?
  supplierPhone   String?
  supplierAddress String?
  supplierCity    String?
  supplierCountry String? // ISO country code

  // Invoice identification — from XML
  invoiceNumber String // cbc:ID
  issueDate     DateTime // cbc:IssueDate
  dueDate       DateTime? // cbc:DueDate (not present for credit notes)
  currencyCode  String    @default("DKK") // cbc:DocumentCurrencyCode

  // Classification
  format          EInvoiceFormat @default(OIOUBL)
  documentType    EInvoiceType   @default(INVOICE)
  customizationId String? // cbc:CustomizationID
  profileId       String? // cbc:ProfileID

  // Line items — stored as JSON for flexibility
  // Shape: [{ id, description, quantity, unitCode, unitPrice, vatPercent, vatCategoryCode, lineAmount }]
  lineItems Json
  lineCount Int  @default(0)

  // Totals — extracted from XML
  taxExclusiveAmount Decimal @default(0) @db.Decimal(18, 2)
  taxAmount          Decimal @default(0) @db.Decimal(18, 2)
  taxInclusiveAmount Decimal @default(0) @db.Decimal(18, 2)
  payableAmount      Decimal @default(0) @db.Decimal(18, 2)

  // Payment info — extracted from XML
  paymentMeansCode String? // e.g., "30" for credit transfer
  paymentAccountId String? // IBAN or bank account

  // Original XML — stored for reference and re-processing
  rawXml String // Original XML content

  // Workflow
  status          ReceivedInvoiceStatus @default(RECEIVED)
  rejectionReason String? // User-provided reason if rejected
  approvedBy      String? // userId who approved
  approvedAt      DateTime?
  postedBy        String? // userId who posted to journal
  postedAt        DateTime?
  journalEntryId  String? // JournalEntry created from this e-invoice

  // Response XML — generated after receiving
  responseXml  String? // Application Response / Message Level Response XML
  responseType String? // "APPLICATION_RESPONSE" | "MESSAGE_LEVEL_RESPONSE" | "INVOICE_RESPONSE"

  // Validation
  validationErrors   String? // JSON array of errors from parsing
  validationWarnings String? // JSON array of warnings

  // Meta
  notes     String? // User notes
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  userId    String? // User who received/imported
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, invoiceNumber]) // Prevent duplicate invoice numbers within a tenant
  @@index([companyId, status])
  @@index([companyId, issueDate])
  @@index([companyId, supplierCvr])
  @@index([userId])
  @@index([createdAt])
}

// ─── VAT SUBMISSION (FASE 5) ──────────────────────────────────
// Tracks VAT report submissions to Skattestyrelsen (Danish Tax Authority).
// Supports quarterly reporting with OAuth2 authentication.

enum VATSubmissionStatus {
  DRAFT // Prepared but not yet submitted
  SUBMITTED // Successfully sent to Skattestyrelsen
  ACCEPTED // Acknowledged by Skattestyrelsen
  REJECTED // Rejected by Skattestyrelsen
  ERROR // Transmission error
}

enum VATReportingPeriod {
  Q1 // January – March
  Q2 // April – June
  Q3 // July – September
  Q4 // October – December
  YEARLY // Full year (for annual reporting)
}

model VATSubmission {
  id String @id @default(cuid())

  // Period identification
  year       Int // e.g., 2026
  period     VATReportingPeriod // Q1, Q2, Q3, Q4, YEARLY
  periodFrom DateTime // Start of reporting period
  periodTo   DateTime // End of reporting period

  // VAT data snapshot (frozen at submission time)
  totalOutputVAT Decimal @default(0) @db.Decimal(18, 2)
  totalInputVAT  Decimal @default(0) @db.Decimal(18, 2)
  netVATPayable  Decimal @default(0) @db.Decimal(18, 2)
  vatDataJson    Json // Full VAT breakdown at time of submission

  // Submission tracking
  status       VATSubmissionStatus @default(DRAFT)
  submittedAt  DateTime?
  submittedBy  String? // userId who submitted
  referenceId  String? // Skattestyrelsen reference/receipt number
  responseXml  String? // Response from Skattestyrelsen
  errorMessage String?
  errorCode    String?

  // Meta
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  companyId       String
  company         Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  submittedByUser User?    @relation(fields: [submittedBy], references: [id], onDelete: SetNull)

  @@unique([companyId, year, period])
  @@index([companyId, status])
  @@index([companyId, year])
  @@index([submittedAt])
}

// ─── E-INVOICE SENDINGS (FASE 4) ──────────────────────────────
// Tracks each attempt to send an outgoing e-invoice via NemHandel or Peppol.
// Supports retry logic, status tracking, and full audit trail.

model EInvoiceSending {
  id String @id @default(cuid())

  // What is being sent
  invoiceId String // FK to Invoice
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  // Channel and format
  channel EInvoiceSendChannel
  format  EInvoiceFormat // OIOUBL | PEPPOL_BIS

  // Recipient
  recipientName       String
  recipientCvr        String?
  recipientEAN        String? // GLN/EAN (alternative to CVR)
  recipientEndpointId String? // Full endpoint ID with scheme

  // Status tracking
  status      EInvoiceSendStatus @default(PENDING)
  sentAt      DateTime? // When the transmission started
  deliveredAt DateTime? // When delivery confirmation received
  acceptedAt  DateTime? // When recipient acknowledged

  // Error handling
  errorCode    String? // Machine-readable error code
  errorMessage String? // Human-readable error message
  retryCount   Int       @default(0)
  maxRetries   Int       @default(3)
  nextRetryAt  DateTime? // Scheduled retry timestamp

  // Tracking
  messageId   String? // Message ID from NemHandel/Peppol network
  responseXml String? // Response XML from the network/receiver

  // Storecove-specific tracking
  storecoveSubmissionId String? // Storecove submission ID (for status polling)
  storecoveStorecoveId  String? // Storecove internal ID (numeric, stored as string)

  // Audit
  sentBy    String // userId who initiated the send
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, status])
  @@index([invoiceId])
  @@index([companyId, channel])
  @@index([companyId, createdAt])
  @@index([sentBy])
  @@index([nextRetryAt])
}

// ─── PROJECT ACCOUNTING ──────────────────────────────────────────

model Project {
  id          String        @id @default(cuid())
  name        String // "Hjemmeside redesign"
  code        String? // Kort kode: "PRJ-001"
  description String? // Valgfri beskrivelse
  color       String? // Visuel farve-tag: "#0d9488"
  status      ProjectStatus @default(ACTIVE)
  startDate   DateTime? // Projektets startdato
  endDate     DateTime? // Forventet/ reel slutdato
  budgetTotal Decimal?      @db.Decimal(18, 2) // Valgfri samlet projektbudget
  customerId  String? // Valgfri kunde-kobling
  companyId   String
  company     Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer    Contact?      @relation(fields: [customerId], references: [id], onDelete: SetNull)

  // Relations
  journalLines   JournalEntryLine[]
  invoices       Invoice[]
  budgetEntries  ProjectBudgetEntry[]
  transactions   Transaction[] // FASE 4: transactions attached to this project
  budgets        Budget[] // FASE 4: project-scoped budgets
  // Sessions that currently have this project active (project mode)
  activeSessions Session[]            @relation("ActiveProjectSession")

  // Meta
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@unique([companyId, code])
  @@index([companyId, status])
  @@index([companyId, customerId])
}

model ProjectBudgetEntry {
  id        String   @id @default(cuid())
  projectId String
  companyId String // Denormalized for query performance
  accountId String
  january   Decimal  @default(0) @db.Decimal(18, 2)
  february  Decimal  @default(0) @db.Decimal(18, 2)
  march     Decimal  @default(0) @db.Decimal(18, 2)
  april     Decimal  @default(0) @db.Decimal(18, 2)
  may       Decimal  @default(0) @db.Decimal(18, 2)
  june      Decimal  @default(0) @db.Decimal(18, 2)
  july      Decimal  @default(0) @db.Decimal(18, 2)
  august    Decimal  @default(0) @db.Decimal(18, 2)
  september Decimal  @default(0) @db.Decimal(18, 2)
  october   Decimal  @default(0) @db.Decimal(18, 2)
  november  Decimal  @default(0) @db.Decimal(18, 2)
  december  Decimal  @default(0) @db.Decimal(18, 2)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  account Account @relation(fields: [accountId], references: [id])

  @@unique([projectId, accountId])
  @@index([projectId])
  @@index([companyId])
  @@index([accountId])
}

// ─── SUBSCRIPTION PAYMENTS (FASE 5 — Flatpay integration) ──────────
// Tracks payment sessions created with Flatpay for paid subscription
// plans. A Payment row is created when the user selects a paid plan and
// is redirected to Flatpay's hosted checkout. The status is updated
// when Flatpay redirects back (callback) or sends a webhook.

enum PaymentStatus {
  pending // Created, waiting for the user to complete payment
  succeeded // Payment confirmed by Flatpay — plan activated
  failed // Payment failed or was declined
  cancelled // User cancelled / abandoned the payment
  refunded // Payment was refunded
}

model Payment {
  id                String        @id @default(cuid())
  // The AlphaFlow user + company that initiated the payment
  userId            String
  companyId         String
  // The plan tier the user is paying for
  planTier          PlanTier
  // The amount + currency charged (in minor units? No — DKK øre as integer)
  amount            Int // Amount in øre (1 DKK = 100 øre)
  currency          String        @default("DKK")
  // Binding period in months (12 / 24 / 36) — stored for the activation step
  bindingMonths     Int           @default(0)
  // Flatpay's payment/session identifier (returned when the session is created)
  flatpayPaymentId  String? // Flatpay's payment ID
  flatpaySessionUrl String? // Hosted checkout URL the user is redirected to
  // Status tracking
  status            PaymentStatus @default(pending)
  // Metadata from Flatpay (raw webhook payload, error messages, etc.)
  metadata          Json?
  // Timestamps
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  completedAt       DateTime? // When the payment was confirmed/failed

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([companyId])
  @@index([status])
  @@index([flatpayPaymentId])
}

// ─── Contact Form Submissions ───────────────────────────────────────
// Stores messages submitted via the public /contact marketing page.
// No auth required — this is a public endpoint.

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  company   String?
  subject   String
  message   String
  ipAddress String?
  userAgent String?
  // new | read | replied | archived
  status    String   @default("new")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([createdAt])
  @@index([email])
}
