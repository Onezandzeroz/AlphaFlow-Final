// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── LEGACY ENUMS ──────────────────────────────────────────────────

enum TransactionType {
  SALE
  PURCHASE
  SALARY
  BANK
  Z_REPORT
  PRIVATE
  ADJUSTMENT
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  CANCELLED
}

// ─── CORE ACCOUNTING ENUMS ────────────────────────────────────────

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
}

enum AccountGroup {
  CASH
  BANK
  RECEIVABLES
  INVENTORY
  FIXED_ASSETS
  OTHER_ASSETS
  PAYABLES
  SHORT_TERM_DEBT
  LONG_TERM_DEBT
  OTHER_LIABILITIES
  SHARE_CAPITAL
  RETAINED_EARNINGS
  SALES_REVENUE
  OUTPUT_VAT
  OTHER_REVENUE
  INPUT_VAT
  COST_OF_GOODS
  PERSONNEL
  OTHER_OPERATING
  FINANCIAL_EXPENSE
  FINANCIAL_INCOME
  TAX
}

enum JournalEntryStatus {
  DRAFT
  POSTED
  CANCELLED
}

enum ContactType {
  CUSTOMER
  SUPPLIER
  BOTH
}

enum PeriodStatus {
  OPEN
  CLOSED
}

enum VATCode {
  S25
  S12
  S0
  SEU
  K25
  K12
  K0
  KEU
  KUF
  NONE
}

enum RecurringFrequency {
  DAILY
  WEEKLY
  MONTHLY
  QUARTERLY
  YEARLY
}

enum RecurringStatus {
  ACTIVE
  PAUSED
  COMPLETED
}

enum ReconciliationStatus {
  UNMATCHED
  MATCHED
  MANUAL
  AI_SUGGESTED
}

enum BankConnectionStatus {
  ACTIVE
  EXPIRED
  PENDING
  REVOKED
  ERROR
}

enum SyncStatus {
  SUCCESS
  PARTIAL
  FAILED
  PENDING
}

// ─── E-INVOICE ENUMS (FASE 3 & 4) ─────────────────────────────────

enum ReceivedInvoiceStatus {
  RECEIVED // Incoming e-invoice parsed and stored
  APPROVED // User approved for booking
  REJECTED // User rejected
  POSTED // Journal entry created from e-invoice
}

enum EInvoiceFormat {
  OIOUBL // OIOUBL (Danish national e-invoice format)
  PEPPOL_BIS // Peppol BIS Billing 3.0
}

enum EInvoiceType {
  INVOICE // 380 — Commercial invoice
  CREDIT_NOTE // 381 — Credit note
  CORRECTED // 384 — Corrected invoice
  SELF_BILLED // 389 — Self-billed invoice
}

enum EInvoiceSendChannel {
  NEMHANDEL_OIOUBL // OIOUBL via NemHandel network
  PEPPOL_BIS // Peppol BIS Billing 3.0 via Access Point
  STORECOVE // Peppol BIS Billing 3.0 via Storecove Access Point
}

enum EInvoiceSendStatus {
  PENDING // Queued for sending
  QUEUED // Handed off to mini-service
  SENDING // Actively being transmitted
  DELIVERED // Successfully delivered to recipient
  ACCEPTED // Recipient acknowledged (positive response)
  FAILED // Transmission or delivery failed
  REJECTED // Recipient rejected the invoice
  CANCELLED // Cancelled by user before sending
}

// ─── MULTI-TENANT ENUMS ───────────────────────────────────────────

enum CompanyRole {
  OWNER // Full control + can transfer ownership, manage members
  ADMIN // Full control except ownership transfer and member removal of OWNER
  ACCOUNTANT // Can create/edit all accounting data, cannot manage members or settings
  VIEWER // Read-only access to all accounting data
  AUDITOR // Read-only + can export reports and run audits
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
  REVOKED
}

// ─── PROJECT ACCOUNTING ENUMS ────────────────────────────────────

enum ProjectStatus {
  ACTIVE
  ON_HOLD
  COMPLETED
  CANCELLED
}

// ─── SUBSCRIPTION PLAN TIERS ───────────────────────────────────────
// The tier determines which features a tenant can access. Set on the
// Company model because plans are purchased by the tenant OWNER and
// apply to ALL team members. The App Owner activates paid tiers via
// the oversight UI (/api/oversight/subscription).

enum PlanTier {
  free // Gratis — revenue ≤ 50.000 kr.
  monthly // Månedlig — 199 kr./md., no commitment
  annual // Pro — 169 kr./md., 12-month binding
  twoyear // Business — 149 kr./md., 24-month binding (frontend id: "2year")
  threeyear // Business Extended — 145 kr./md., 36-month binding (frontend id: "3year")
}

// ─── COMPANY (TENANT ENTITY) ──────────────────────────────────────
// Replaces the old CompanyInfo model. This IS the tenant boundary.

model Company {
  id              String  @id @default(cuid())
  name            String // Company display name
  logo            String? // Base64 or URL
  showCompanyLogo Boolean @default(false) // Show company logo in AlphaFlow sidebar instead of AlphaFlow logo

  // Business registration
  address       String    @default("")
  phone         String    @default("")
  email         String    @default("")
  cvrNumber     String    @default("")
  cvrVerifiedAt DateTime? // Timestamp of last successful CVR register verification
  companyType   String? // ApS, A/S, IVS, Enkeltmandsvirksomhed

  // Invoice settings
  invoicePrefix        String  @default("INV")
  invoiceTerms         String  @default("Betaling forfalder senest 30 dage efter\nfakturadatoen. Ved forsinkelse, påløber\nder renter efter Renteloven.\nEvt. spørgsmål, så kontakt os venligst.")
  invoiceNotesTemplate String?
  nextInvoiceSequence  Int     @default(1)
  currentYear          Int     @default(2026)

  // Journal entry numbering (Bogføringsloven — fortløbende bilagsnummer)
  journalPrefix       String @default("BIL") // Prefix for bilagsnumre
  nextJournalSequence Int    @default(1) // Næste fortløbende nummer

  // Bank details
  bankName         String  @default("")
  bankAccount      String  @default("")
  bankRegistration String  @default("")
  bankIban         String?
  bankStreet       String?
  bankCity         String?
  bankCountry      String?

  // Dashboard widget visibility (JSON map: { widgetId: boolean })
  dashboardWidgets Json?

  // Two-Factor Authentication (tenant-level toggle)
  // When true, ALL users in this tenant must have 2FA enabled
  twoFactorRequired Boolean @default(false)

  // E-invoicing configuration (FASE 4)
  einvoiceEnabled            Boolean              @default(false)
  einvoiceDefaultChannel     EInvoiceSendChannel? // Preferred default sending channel
  einvoiceEndpointId         String? // CVR-based EndpointID for e-invoicing (scheme 0184)
  einvoiceGLN                String? // GLN/EAN number (optional alternative to CVR)
  einvoicePeppolAs4Id        String? // Peppol AS4 identifier (e.g., 0188:CVR12345678)
  einvoiceRegistrationNo     String? // NemHandelsregisteret registration number
  einvoiceRegisteredAt       DateTime? // When registered in NemHandelsregisteret
  einvoiceAutoSendOnFinalize Boolean              @default(false) // Auto-send when invoice is finalized
  einvoiceDeliveryMode       String? // 'manual' or 'automatic' — null = not yet chosen

  // Storecove Access Point integration (Peppol delivery)
  storecoveConnected     Boolean   @default(false) // Whether Storecove API is configured
  storecoveApiKeyId      String? // Storecove API key ID (last 4 chars stored for identification)
  storecoveLegalEntityId Int? // Storecove legal entity ID for this company
  storecoveConnectedAt   DateTime? // When Storecove was connected
  storecoveLastTestedAt  DateTime? // Last successful connection test

  // ── Project Mode gating (FASE 4 — SuperDev controls per-tenant visibility) ──
  // When false, the Projects section, ProjectSelector dropdowns, project
  // accounts and the project-mode banner are all HIDDEN for this tenant.
  // SuperDev (AppOwner) toggles this per company from company settings.
  projectModeEnabled Boolean @default(false)

  // ── Subscription plan (FASE 5 — feature gating) ──
  // The active plan tier determines which features the tenant can access.
  // Defaults to 'free' for all new + legacy tenants. Paid tiers are activated
  // by the App Owner via /api/oversight/subscription. See lib/plan-features.ts
  // for the tier → feature mapping.
  planTier        PlanTier  @default(free)
  planPurchasedAt DateTime? // When the current plan was activated
  planExpiresAt   DateTime? // End of binding period (null for free + monthly)
  planActivatedBy String? // userId of the App Owner who set the paid plan (audit trail)
  planNotes       String? // SuperDev free-text note (e.g. "granted as courtesy")

  // Meta
  isDemo    Boolean  @default(false) // Demo company flag — only the shared demo company should be true
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  members                 UserCompany[]
  invitations             Invitation[]
  transactions            Transaction[]
  invoices                Invoice[]
  accounts                Account[]
  journalEntries          JournalEntry[]
  contacts                Contact[]
  fiscalPeriods           FiscalPeriod[]
  bankStatements          BankStatement[]
  bankConnections         BankConnection[]
  recurringEntries        RecurringEntry[]
  budgets                 Budget[]
  backups                 Backup[]
  auditLogs               AuditLog[]
  sessions                Session[]
  oversightSessions       Session[]                @relation("OversightCompany")
  hermesAgent             HermesAgent?
  standardAccountMappings StandardAccountMapping[]
  receivedInvoices        ReceivedInvoice[]
  eInvoiceSendings        EInvoiceSending[]
  vatSubmissions          VATSubmission[]
  projects                Project[]
  payments                Payment[]

  @@unique([name])
  @@index([isActive])
  @@index([cvrNumber])
  @@index([planTier])
}

// ─── USER-COMPANY JUNCTION ────────────────────────────────────────

model UserCompany {
  id        String      @id @default(cuid())
  userId    String
  companyId String
  role      CompanyRole @default(VIEWER)
  joinedAt  DateTime    @default(now())
  invitedBy String?

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([userId, companyId])
  @@index([userId])
  @@index([companyId])
  @@index([role])
}

// ─── INVITATION SYSTEM ────────────────────────────────────────────

model Invitation {
  id         String           @id @default(cuid())
  companyId  String
  email      String // Invitee email (lowercased, trimmed)
  role       CompanyRole      @default(VIEWER)
  token      String           @unique
  status     InvitationStatus @default(PENDING)
  invitedBy  String // userId of the inviter
  expiresAt  DateTime
  acceptedAt DateTime?
  acceptedBy String? // userId who accepted
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([email, status])
  @@index([companyId, status])
  @@index([token])
  @@index([expiresAt])
}

// ─── USER ─────────────────────────────────────────────────────────

model User {
  id                     String    @id @default(cuid())
  email                  String    @unique
  password               String // bcrypt hash
  emailVerified          Boolean   @default(false)
  emailVerificationToken String?   @unique
  emailVerifiedAt        DateTime?
  resetPasswordToken     String?   @unique
  resetPasswordExpires   DateTime?
  businessName           String?
  sidebarPrefs           Json?
  userPrefs              Json?
  demoModeEnabled        Boolean   @default(false)
  isSuperDev             Boolean   @default(false) // AlphaAi SUPER_DEV read-only cross-tenant access
  trialClaimedAt         DateTime? // When user self-claimed their one-time free trial (not set for owner-granted trials)
  subscriptionRevokedAt  DateTime? // Set by App Owner to revoke subscription-based free-tier access (revenue gate). Does NOT affect .tbkey proof access.

  // Two-Factor Authentication (TOTP)
  // twoFactorSecret: AES-256-GCM encrypted TOTP secret (base32-encoded)
  // twoFactorBackupCodes: AES-256-GCM encrypted JSON array of hashed backup codes
  twoFactorSecret      String?
  twoFactorBackupCodes String? // Encrypted JSON: [hashedCode1, hashedCode2, ...]
  twoFactorEnabled     Boolean   @default(false)
  twoFactorEnabledAt   DateTime?

  // Account deactivation — replaces hard deletion to preserve audit trail
  // per Bogføringsloven §10-12 (5-year retention obligation takes precedence
  // over GDPR Art. 17 deletion requests per GDPR Art. 17(3)(c)).
  // A deactivated user cannot log in, but all their data and audit logs are preserved.
  deactivatedAt      DateTime? // Null = active account. Set = account deactivated at this timestamp.
  deactivationReason String? // 'self_request' | 'admin_action' | 'sole_company_cleanup'

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  transactions     Transaction[]
  invoices         Invoice[]
  sessions         Session[]
  auditLogs        AuditLog[]
  backups          Backup[]
  accounts         Account[]
  journalEntries   JournalEntry[]
  contacts         Contact[]
  fiscalPeriods    FiscalPeriod[]
  bankStatements   BankStatement[]
  bankConnections  BankConnection[]
  recurringEntries RecurringEntry[]
  budgets          Budget[]

  // Multi-tenant relations
  companies          UserCompany[]
  performedAuditLogs AuditLog[]         @relation("PerformedByUser")
  notificationReads  NotificationRead[]
  vatSubmissions     VATSubmission[]
  projects           Project[]
  payments           Payment[]
}

// ─── SESSION (with activeCompanyId) ───────────────────────────────

model Session {
  id                 String   @id @default(cuid())
  token              String   @unique
  userId             String
  activeCompanyId    String?
  oversightCompanyId String? // When set, the App Owner is overseeing this tenant in read-only mode
  // ── Project Mode (FASE 4) ──
  // When set, the user is working inside this project's context: the project
  // banner is shown, forms auto-attach new entries to this project, and the
  // ProjectSelector is locked. Cleared by "Tilbage til tenant-regnskabet".
  activeProjectId    String?
  ipAddress          String?
  userAgent          String?
  expiresAt          DateTime
  createdAt          DateTime @default(now())

  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  activeCompany    Company? @relation(fields: [activeCompanyId], references: [id], onDelete: SetNull)
  oversightCompany Company? @relation("OversightCompany", fields: [oversightCompanyId], references: [id], onDelete: SetNull)
  activeProject    Project? @relation("ActiveProjectSession", fields: [activeProjectId], references: [id], onDelete: SetNull)

  @@index([token])
  @@index([userId])
  @@index([expiresAt])
  @@index([activeCompanyId])
  @@index([oversightCompanyId])
  @@index([activeProjectId])
}

// ─── TRANSACTIONS ─────────────────────────────────────────────────

model Transaction {
  id           String          @id @default(cuid())
  date         DateTime
  type         TransactionType @default(SALE)
  amount       Decimal         @db.Decimal(18, 2)
  currency     String          @default("DKK")
  exchangeRate Decimal?        @db.Decimal(12, 6)
  amountDKK    Decimal?        @db.Decimal(18, 2)
  description  String
  vatPercent   Decimal         @default(25.0) @db.Decimal(5, 2)
  receiptImage String?
  invoiceId    String?
  accountId    String?
  projectId    String? // FASE 4: project this transaction belongs to (null = tenant-level)
  cancelled    Boolean         @default(false)
  cancelReason String?
  originalId   String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  userId       String?
  user         User?           @relation(fields: [userId], references: [id], onDelete: SetNull)
  invoice      Invoice?        @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  account      Account?        @relation(fields: [accountId], references: [id])
  project      Project?        @relation(fields: [projectId], references: [id], onDelete: SetNull)
  companyId    String
  company      Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, date])
  @@index([companyId, type, date])
  @@index([userId])
  @@index([accountId])
  @@index([projectId])
}

// ─── INVOICES ─────────────────────────────────────────────────────

model Invoice {
  id               String            @id @default(cuid())
  invoiceNumber    String
  customerName     String
  customerAddress  String?
  customerEmail    String?
  customerPhone    String?
  customerCvr      String?
  issueDate        DateTime
  dueDate          DateTime
  paidDate         DateTime? // Date the invoice was paid (user-selectable; null until status → PAID)
  lineItems        Json
  subtotal         Decimal           @db.Decimal(18, 2)
  vatTotal         Decimal           @db.Decimal(18, 2)
  total            Decimal           @db.Decimal(18, 2)
  currency         String            @default("DKK")
  exchangeRate     Decimal?          @db.Decimal(12, 6)
  status           InvoiceStatus     @default(DRAFT)
  notes            String?
  cancelled        Boolean           @default(false)
  cancelReason     String?
  contactId        String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  userId           String?
  user             User?             @relation(fields: [userId], references: [id], onDelete: SetNull)
  contact          Contact?          @relation(fields: [contactId], references: [id], onDelete: SetNull)
  transactions     Transaction[]
  eInvoiceSendings EInvoiceSending[]
  projectId        String?
  project          Project?          @relation(fields: [projectId], references: [id], onDelete: SetNull)
  companyId        String
  company          Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, invoiceNumber])
  @@index([companyId, status, issueDate])
  @@index([userId])
  @@index([projectId])
}

// ─── AUDIT LOG ────────────────────────────────────────────────────
//
// DATABASE-LEVEL IMMUTABILITY:
// PostgreSQL triggers (see prisma/audit-immutability.sql) prevent
// UPDATE and DELETE on this table at the database level.
// This enforces Bogføringsloven §10-12 beyond application-level controls.
//
// Foreign keys use onDelete: Restrict — you cannot delete a User or
// Company that has AuditLog entries. This is intentional: the audit
// trail must preserve references for the 5-year retention period.
//
// Deployment: bun run scripts/apply-audit-immutability.ts

model AuditLog {
  id                String   @id @default(cuid())
  userId            String?
  companyId         String?
  performedByUserId String?
  action            String
  entityType        String
  entityId          String
  changes           Json?
  metadata          Json?
  createdAt         DateTime @default(now())

  // onDelete: Restrict — prevents deletion of referenced User/Company
  // when AuditLog entries exist. This is required by Bogføringsloven §10-12
  // to maintain an immutable audit trail for 5 years.
  // NOTE: If a user requests GDPR Art. 17 deletion, the 5-year bookkeeping
  // retention obligation takes precedence per GDPR Art. 17(3)(c).
  user            User?    @relation(fields: [userId], references: [id], onDelete: Restrict)
  company         Company? @relation(fields: [companyId], references: [id], onDelete: Restrict)
  performedByUser User?    @relation("PerformedByUser", fields: [performedByUserId], references: [id], onDelete: Restrict)

  @@index([userId])
  @@index([companyId, createdAt])
  @@index([entityType, entityId])
  @@index([action])
  @@index([createdAt])
  @@index([performedByUserId])
}

// ─── BACKUP ───────────────────────────────────────────────────────

model Backup {
  id           String   @id @default(cuid())
  userId       String?
  userEmail    String? // denormalized: tenant owner email for quick reference in DB dashboards
  triggerType  String
  backupType   String
  scope        String   @default("tenant") // "tenant" = tenant-specific JSON snapshot
  filePath     String
  fileSize     Int
  sha256       String?
  encrypted    Boolean  @default(false) // true = AES-256-GCM encrypted .zip.enc file
  status       String   @default("completed")
  errorMessage String?
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  user         User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  companyId    String
  companyName  String? // denormalized: company name for quick reference in DB dashboards
  company      Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, backupType])
  @@index([companyId, createdAt])
  @@index([companyId, scope])
  @@index([userId])
  @@index([backupType])
  @@index([status])
}

// ─── CRON EXECUTION LOG ────────────────────────────────────────────
// Persistent record of every cron cycle run. Enables:
// 1. Missed-run detection: on startup, check if a cycle should have run
//    while the server was down and run it now (catch-up)
// 2. DB-based health: survives server restarts (in-memory maps are lost)
// 3. Audit trail: see exactly when each cycle ran and what happened

model CronExecution {
  id               String    @id @default(cuid())
  jobType          String // "backup_hourly" | "backup_daily" | "backup_weekly" | "backup_monthly" | "backup_cleanup" | "recurring_entries"
  companyId        String? // null for global jobs (cleanup, recurring)
  status           String // "success" | "error" | "skipped" | "partial"
  companiesTotal   Int       @default(0) // how many companies were processed
  companiesSuccess Int       @default(0)
  companiesError   Int       @default(0)
  companiesSkipped Int       @default(0)
  errorMessage     String? // first error message (if any)
  startedAt        DateTime  @default(now())
  finishedAt       DateTime?
  durationMs       Int       @default(0)
  catchup          Boolean   @default(false) // true if this run was a catch-up from a missed window

  @@index([jobType, startedAt])
  @@index([companyId, jobType])
  @@index([status, startedAt])
}

// ─── CHART OF ACCOUNTS ────────────────────────────────────────────

model Account {
  id                   String                   @id @default(cuid())
  number               String
  name                 String
  nameEn               String?
  type                 AccountType
  group                AccountGroup
  description          String?
  isActive             Boolean                  @default(true)
  isSystem             Boolean                  @default(false)
  // FASE 2: Standardkontoplan mapping
  publicStandardNumber String? // SKAT offentlig standardkontonummer (0-9xxx)
  postingGuide         String? // Brugerdefineret konteringsvejledning per konto
  createdAt            DateTime                 @default(now())
  updatedAt            DateTime                 @updatedAt
  userId               String?
  user                 User?                    @relation(fields: [userId], references: [id], onDelete: SetNull)
  journalLines         JournalEntryLine[]
  budgetEntries        BudgetEntry[]
  projectBudgetEntries ProjectBudgetEntry[]
  transactions         Transaction[]
  standardMappings     StandardAccountMapping[]
  companyId            String
  company              Company                  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, number])
  @@index([companyId, type])
  @@index([companyId, group])
  @@index([userId, type])
  @@index([companyId, publicStandardNumber])
}

// ─── STANDARD ACCOUNT MAPPING (FASE 2) ────────────────────────────

model StandardAccountMapping {
  id                    String   @id @default(cuid())
  companyId             String
  accountId             String // FSR-konto (brugerens egen konto)
  standardAccountNumber String // SKAT offentlig standardkontonummer
  standardAccountName   String // Navn på standardkonto
  mappingType           String   @default("manual") // "auto" | "manual" | "none"
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, accountId])
  @@index([companyId])
  @@index([companyId, standardAccountNumber])
  @@index([accountId])
}

// ─── JOURNAL ENTRIES ──────────────────────────────────────────────

model JournalEntry {
  id            String             @id @default(cuid())
  date          DateTime
  description   String
  reference     String?
  voucherNumber String? // Fortløbende bilagsnummer (f.eks. BIL-2026-0001) — tildeles ved POSTED
  status        JournalEntryStatus @default(DRAFT)
  cancelled     Boolean            @default(false)
  cancelReason  String?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  userId        String?
  user          User?              @relation(fields: [userId], references: [id], onDelete: SetNull)
  lines         JournalEntryLine[]
  documents     Document[]
  companyId     String
  company       Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, date])
  @@index([companyId, status, date])
  @@index([userId, date])
  @@index([companyId, voucherNumber])
}

model JournalEntryLine {
  id             String              @id @default(cuid())
  journalEntryId String
  companyId      String // Denormalized from JournalEntry for direct query performance
  accountId      String
  debit          Decimal             @default(0) @db.Decimal(18, 2)
  credit         Decimal             @default(0) @db.Decimal(18, 2)
  vatCode        VATCode?
  description    String?
  createdAt      DateTime            @default(now())
  journalEntry   JournalEntry        @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  account        Account             @relation(fields: [accountId], references: [id])
  bankMatches    BankStatementLine[]
  projectId      String?
  project        Project?            @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([journalEntryId])
  @@index([companyId, accountId])
  @@index([accountId])
  @@index([projectId])
}

// ─── CONTACTS ─────────────────────────────────────────────────────

model Contact {
  id         String      @id @default(cuid())
  name       String
  cvrNumber  String?
  email      String?
  phone      String?
  address    String?
