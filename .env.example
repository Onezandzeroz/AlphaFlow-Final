# ─── AlphaFlow Environment Variables ────────────────────────────────
# Copy this file to .env and fill in your values.
# All variables are optional — defaults are used when not set.



# Database — PostgreSQL (Neon)
# REQUIRED for production. Get this from your Neon dashboard.
# For Neon pooled connections (recommended for serverless / edge):
#   postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=



# ─── Hermes AI — OpenRouter (LLM provider) ─────────────────────────
# Hermes (the AI accounting assistant overlay) calls OpenRouter's
# OpenAI-compatible Chat Completions API. This replaces the
# sandbox-only z-ai-web-dev-sdk and is REQUIRED for Hermes to answer
# chats in production.
#
# Get your API key at: https://openrouter.ai → Dashboard → Keys
# Free models (suffix ":free"): https://openrouter.ai/models?q=free
# Recommended free model for Danish accounting advice:
#   meta-llama/llama-3.3-70b-instruct:free
#
# NOTE: Adding $5 of credits (even if you only use free models) lifts
# the free-tier rate limits from ~50 req/day to ~1000 req/day.
#
# The PM2 ecosystem file does NOT auto-load this .env — set
# OPENROUTER_API_KEY in the hermes-agent app block of ecosystem.config.js too.
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free
# Optional — shown in OpenRouter dashboard for attribution/ranking
OPENROUTER_APP_NAME=AlphaFlow
OPENROUTER_APP_URL=https://alphaflow.dk



# ─── Backup Scheduler ───────────────────────────────────────────────
# Timezone used for all backup cron schedules (hourly/daily/weekly/monthly +
# daily cleanup). Danish Bookkeeping Law (Bogføringsloven §15) requires backups
# at fixed Danish local times, so this defaults to Europe/Copenhagen. The VPS
# system timezone does NOT need to match. Override only if deploying elsewhere.
BACKUP_TIMEZONE=Europe/Copenhagen

# Set to "true" to fully disable the backup scheduler (e.g. for a staging
# instance that must never write backups). Leave unset in production.
# DISABLE_BACKUP_SCHEDULER=false



# ─── Scanner Service ────────────────────────────────────────────────
# Python mini-service for document scanning, OCR, and VLM extraction.
# The shared API key authenticates communication between the host app
# (proxy route /api/ocr/pdf) and the scanner service.
#
# IMPORTANT: SCANNER_API_KEY (host app) MUST match API_SHARED_KEY
# in the mini-service's .env. Change both to the same strong secret.
#
# Default: scanner-dev-key-2026 (for development only)
# Production: Use a long random string, e.g. openssl rand -hex 32

# Shared API key for Scanner proxy routes (host app)
SCANNER_API_KEY=scanner-dev-key-2026

# Port the Scanner Service runs on (default: 3005)
SCANNER_PORT=3005


# ─── Email / SMTP ──────────────────────────────────────────────────
# Required for sending real emails (verification, password reset, invitations).
# If SMTP_HOST, SMTP_USER, or SMTP_PASS are not set, emails are logged
# to the console in dev mode (no emails are sent).

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Sender email address shown in the "From" field
EMAIL_FROM=noreply@alphaflow.dk

# Public base URL used in email links (verification, reset, invites)
# IMPORTANT: Must match your public domain in production
# Example: https://alphaflow.dk
APP_URL=https://alphaflow.dk



# ─── TokenPay Access Service ──────────────────────────────────────
# Token-gated access control module. The shared API key authenticates
# communication between the host app (proxy routes) and the access service.
#
# IMPORTANT: TOKENPAY_API_KEY (host app) MUST match API_SHARED_KEY
# in the mini-service's environment. Change both to the same strong secret.
#
# Default: tokenpay-dev-key-2026 (for development only)
# Production: Use a long random string, e.g. openssl rand -hex 32

# Shared API key for TokenPay proxy routes (host app)
TOKENPAY_API_KEY=tokenpay-dev-key-2026

# Port the TokenPay Access Service runs on (default: 3100)
NEXT_PUBLIC_TOKENPAY_PORT=3100



# ─── AlphaFlow — At-Rest Encryption ─────────────────────────────────
# AES-256-GCM key for encrypting sensitive data (bank tokens, backup files)
# stored in the database and on disk. REQUIRED for production.
#
# The key is NEVER stored in the database — only in this env var.
# If you lose this key, all encrypted bank tokens and backup files become
# permanently unrecoverable. Store it securely (e.g., in a secrets manager).
#
# This key is used for:
#   - Bank access/refresh tokens (AES-256-GCM in database)
#   - Backup ZIP files (AES-256-GCM encrypted .zip.enc on disk)
#   - 2FA TOTP secrets and backup codes
#
# Generate a new key with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#
# Format: 64-character hex string (32 bytes)
ENCRYPTION_KEY=



# ─── TokenBay-ZIPProof Encryption ────────────────────────────
# AES-256-GCM key for decrypting .tbkey proof files.
# This key MUST match the PROOF_ENCRYPTION_KEY in TokenBay-ZIPProof.
# The service will NOT start if this is not set.
#
# Generate a new key with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#
# Format: 64-character hex string (32 bytes)



# ─── Skattestyrelsen Moms API ───────────────────────────────────────
# OAuth2 credentials for live VAT submission to the Danish Tax Authority.
# When not configured, VAT submissions run in simulation mode.
# Apply for access at: https://nemvirksomhed.dk/
SKAT_API_BASE=https://api.skat.dk/moms
SKAT_CLIENT_ID=
SKAT_CLIENT_SECRET=



# ─── NemHandel / Peppol E-Invoicing ─────────────────────────────────
# Credentials for live e-invoice sending via NemHandel network.
# When not configured, e-invoice operations run in simulation mode.
# Contact a certified Access Point provider (Nets, Pagero, Tradeshift).
NEMHANDEL_API_URL=https://nemhandel.nets.dk/api/v2
NEMHANDEL_API_KEY=
PEPPOL_AP_URL=https://peppol.accesspoint.dk
NEMHANDEL_SIMULATION_MODE=true  # Set to 'false' for production



# ─── Storecove Access Point (Recommended) ────────────────────────────
# Peppol Access Point provider for direct e-invoice delivery.
# Storecove handles Peppol BIS Billing 3.0 routing, NemHandel gatewaying,
# and delivery status tracking via webhooks.
#
# When STORECOVE_API_KEY is set, production mode is used automatically.
# When not set, Storecove operations run in simulation mode.
#
# Get your API key at: https://www.storecove.com/
# Dashboard: https://dashboard.storecove.com/
#
# Workflow: Generate XML → Validate → Send to Storecove API → Auto-delivered
STORECOVE_API_URL=https://api.storecove.com/v2
STORECOVE_API_KEY=
STORECOVE_WEBHOOK_SECRET=

# Webhook endpoint to configure in Storecove dashboard:
#   https://your-domain.com/api/storecove/webhook



# ─── Frisbii / Flatpay (Subscription Payments) ─────────────────────
# Frisbii (formerly Billwerk+ / Reepay) is the payment provider for
# paid subscription plans. The checkout uses Frisbii Pay Checkout
# (hosted payment page) via the Checkout API.
#
# When FLATPAY_API_KEY is NOT set, the integration runs in "mock mode"
# (payments auto-succeed — for local development/testing).
#
# Get your API credentials at:
#   https://app.frisbii.com → Developers → API Credentials
# The private key looks like: priv_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
#
# Docs:
#   https://docs.frisbii.com/docs/new-web-shop
#   https://docs.frisbii.com/docs/billwerk-checkout
#
# Webhook endpoint to configure in Frisbii admin UI:
#   https://your-domain.com/api/subscription/payment-webhook
# Listen for events: invoice_authorized, invoice_settled, invoice_failed
FLATPAY_API_KEY=
FLATPAY_API_BASE_URL=https://checkout-api.frisbii.com/v1
FLATPAY_WEBHOOK_SECRET=



# ─── CVR Register Lookup (Erhvervsstyrelsen / VIRK) ────────────────
# System-til-system adgang til Det Centrale Virksomhedsregister (CVR).
# AlphaFlow bruger Elasticsearch API'et på distribution.virk.dk til at
# verificere at indtastede CVR-numre reelt eksisterer, og til at
# auto-udfylde firmanavn + adresse når en virksomhed findes.
#
# Få credentials hos Erhvervsstyrelsen:
#   https://datacvr.virk.dk/artikel/system-til-system-adgang-til-registeringstekster
#
# Når CVR_API_USERNAME + CVR_API_PASSWORD er sat OG CVR_SIMULATION_MODE
# ikke er 'false', foretages rigtige opslag. Ellers køres i simulation
# mode (mock-data, ingen rigtige kald) så funktionen kan udvikles/demos.
CVR_API_BASE_URL=http://distribution.virk.dk
CVR_API_USERNAME=
CVR_API_PASSWORD=
CVR_SIMULATION_MODE=true  # Sæt til 'false' i produktion med rigtige credentials
