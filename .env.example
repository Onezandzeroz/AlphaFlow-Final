# ─── AlphaFlow Environment Variables ────────────────────────────────
# Copy this file to .env and fill in your values.
# All variables are optional — defaults are used when not set.

# Database — PostgreSQL (Neon)
# REQUIRED for production. Get this from your Neon dashboard.
# For Neon pooled connections (recommended for serverless / edge):
#   postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=

# ─── Email / SMTP ──────────────────────────────────────────────────
# Required for sending real emails (verification, password reset, invitations).
# If SMTP_HOST, SMTP_USER, or SMTP_PASS are not set, emails are logged
# to the console in dev mode (no emails are sent).

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Sender email address shown in the "From" field
EMAIL_FROM=noreply@alphaflow.dk

# Public base URL used in email links (verification, reset, invites)
# IMPORTANT: Must match your public domain in production
# Example: https://alphaflow.dk
APP_URL=https://alphaflow.dk

# ─── TokenPay Access Service ──────────────────────────────────────
# Token-gated access control module. The shared API key authenticates
# communication between the host app (proxy routes) and the access service.
#
# IMPORTANT: TOKENPAY_API_KEY (host app) MUST match API_SHARED_KEY
# in the mini-service's environment. Change both to the same strong secret.
#
# Default: tokenpay-dev-key-2026 (for development only)
# Production: Use a long random string, e.g. openssl rand -hex 32

# Shared API key for TokenPay proxy routes (host app)
TOKENPAY_API_KEY=tokenpay-dev-key-2026

# Port the TokenPay Access Service runs on (default: 3100)
NEXT_PUBLIC_TOKENPAY_PORT=3100

# ─── AlphaFlow — At-Rest Encryption ─────────────────────────────────
# AES-256-GCM key for encrypting sensitive data (bank tokens, backup files)
# stored in the database and on disk. REQUIRED for production.
#
# The key is NEVER stored in the database — only in this env var.
# If you lose this key, all encrypted bank tokens and backup files become
# permanently unrecoverable. Store it securely (e.g., in a secrets manager).
#
# This key is used for:
#   - Bank access/refresh tokens (AES-256-GCM in database)
#   - Backup ZIP files (AES-256-GCM encrypted .zip.enc on disk)
#   - 2FA TOTP secrets and backup codes
#
# Generate a new key with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#
# Format: 64-character hex string (32 bytes)
ENCRYPTION_KEY=

# ─── TokenBay-ZIPProof Encryption ────────────────────────────
# AES-256-GCM key for decrypting .tbkey proof files.
# This key MUST match the PROOF_ENCRYPTION_KEY in TokenBay-ZIPProof.
# The service will NOT start if this is not set.
#
# Generate a new key with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#
# Format: 64-character hex string (32 bytes)
PROOF_ENCRYPTION_KEY=

# ─── Skattestyrelsen Moms API ───────────────────────────────────────
# OAuth2 credentials for live VAT submission to the Danish Tax Authority.
# When not configured, VAT submissions run in simulation mode.
# Apply for access at: https://nemvirksomhed.dk/
SKAT_API_BASE=https://api.skat.dk/moms
SKAT_CLIENT_ID=
SKAT_CLIENT_SECRET=

# ─── NemHandel / Peppol E-Invoicing ─────────────────────────────────
# Credentials for live e-invoice sending via NemHandel network.
# When not configured, e-invoice operations run in simulation mode.
# Contact a certified Access Point provider (Nets, Pagero, Tradeshift).
NEMHANDEL_API_URL=https://nemhandel.nets.dk/api/v2
NEMHANDEL_API_KEY=
PEPPOL_AP_URL=https://peppol.accesspoint.dk
NEMHANDEL_SIMULATION_MODE=true  # Set to 'false' for production
