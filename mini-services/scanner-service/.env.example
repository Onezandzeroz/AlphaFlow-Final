# ─── AlphaFlow Scanner Service — Environment Variables ──────────
# Copy this file to .env and fill in your values.
# All variables are optional — defaults are used when not set.

# ─── Server ───────────────────────────────────────────────────
# Port the service listens on (default: 3005)
PORT=3005

# Environment (development | production)
NODE_ENV=development

# ─── Authentication ───────────────────────────────────────────
# Shared API key for inbound auth. The host app (AlphaFlow) sends
# this in the `X-Access-Service-Key` header.
# IMPORTANT: SCANNER_API_KEY (host app) MUST match API_SHARED_KEY (here).
# Default dev key: scanner-dev-key-2026
# Production: openssl rand -hex 32
API_SHARED_KEY=scanner-dev-key-2026

# ─── Database ─────────────────────────────────────────────────
# SQLite path (relative to service root). Auto-created on first run.
# WAL mode enabled for concurrent read/write safety.
DATABASE_PATH=./data/scanner.db

# ─── VLM / LLM (Claude Sonnet 4 via Anthropic) ────────────────
# Get from: https://console.anthropic.com/
# Required for VLM extraction. If unset, service falls back to
# Tesseract + Danish regex parser only (lower accuracy on PDFs).
ANTHROPIC_API_KEY=

# Model name (default: claude-sonnet-4-20250514)
# Other options: claude-3-5-sonnet-20241022 (cheaper), claude-opus-4-20250514
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Max tokens for VLM response (default: 4096)
VLM_MAX_TOKENS=4096

# ─── Webhook ──────────────────────────────────────────────────
# Optional: when set, the service POSTs the OCR result back to
# this URL on job completion (HMAC-SHA256 signed with API_SHARED_KEY).
# Example: https://alphaflow.dk/api/scanner/callback
HOST_CALLBACK_URL=

# ─── Limits ───────────────────────────────────────────────────
# Max upload size in MB (default: 10 — matches existing /api/ocr/pdf)
MAX_FILE_SIZE_MB=10

# Max PDF pages to process (default: 10 — increased from original 5)
MAX_PAGES=10

# ─── OCR ──────────────────────────────────────────────────────
# Tesseract languages (default: dan+eng)
TESSERACT_LANG=dan+eng

# ─── Logging ──────────────────────────────────────────────────
# Log level: debug | info | warning | error
LOG_LEVEL=info
