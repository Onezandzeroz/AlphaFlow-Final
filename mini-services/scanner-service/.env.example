# ─── AlphaFlow Scanner Service — Environment Variables ──────────
# Copy this file to .env and fill in your values.
# All variables are optional — defaults are used when not set.
#
# In development: this .env file is auto-loaded by python-dotenv.
# In production (PM2): env vars come from ecosystem.config.js env block,
# which takes precedence over this file (override=False).

# ─── Server ───────────────────────────────────────────────────
# Port the service listens on (default: 3005)
PORT=3005

# Environment (development | production)
NODE_ENV=development

# ─── Authentication ───────────────────────────────────────────
# Shared API key for inbound auth. The host app (AlphaFlow) sends
# this in the `X-Access-Service-Key` header.
# IMPORTANT: SCANNER_API_KEY (host app) MUST match API_SHARED_KEY (here).
# Default dev key: scanner-dev-key-2026
# Production: openssl rand -hex 32
API_SHARED_KEY=scanner-dev-key-2026

# ─── Database ─────────────────────────────────────────────────
# SQLite path (relative to service root). Auto-created on first run.
# WAL mode enabled for concurrent read/write safety.
DATABASE_PATH=./data/scanner.db

# ─── VLM via OpenRouter (unified with Hermes) ─────────────────
# The scanner-service uses OpenRouter for VLM (invoice/receipt extraction),
# the SAME provider and API key as the Hermes AI assistant.
# Get your key at: https://openrouter.ai → Dashboard → Keys
# This MUST be the same OPENROUTER_API_KEY you use for Hermes.
OPENROUTER_API_KEY=

# OpenRouter base URL (default: https://openrouter.ai/api/v1)
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Vision-capable model for invoice/receipt extraction.
# Browse vision models: https://openrouter.ai/models?capabilities=image
# Default: anthropic/claude-sonnet-4.5 (best quality)
# Alternatives:
#   google/gemini-2.5-flash-preview             (cheaper, fast)
#   meta-llama/llama-3.2-90b-vision-instruct    (open-source)
OPENROUTER_VLM_MODEL=anthropic/claude-sonnet-4.5

# OpenRouter dashboard attribution (optional but recommended)
OPENROUTER_APP_NAME=AlphaFlow
APP_URL=https://alphaflow.dk

# Max tokens for VLM response (default: 4096)
VLM_MAX_TOKENS=4096

# ── DEPRECATED ────────────────────────────────────────────────
# ANTHROPIC_API_KEY / ANTHROPIC_MODEL are no longer used.
# The service calls OpenRouter (not Anthropic directly) for VLM.
# If OPENROUTER_API_KEY is unset, ANTHROPIC_API_KEY's VALUE is used
# as the OpenRouter key (migration safety net) — but the key must be
# an OpenRouter key, not an Anthropic console key.
# Remove these from your .env when migration is complete.
#ANTHROPIC_API_KEY=
#ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ─── Webhook ──────────────────────────────────────────────────
# Optional: when set, the service POSTs the OCR result back to
# this URL on job completion (HMAC-SHA256 signed with API_SHARED_KEY).
# Example: https://alphaflow.dk/api/scanner/callback
HOST_CALLBACK_URL=

# ─── Limits ───────────────────────────────────────────────────
# Max upload size in MB (default: 10 — matches existing /api/ocr/pdf)
MAX_FILE_SIZE_MB=10

# Max PDF pages to process (default: 10 — increased from original 5)
MAX_PAGES=10

# ─── OCR ──────────────────────────────────────────────────────
# Tesseract languages (default: dan+eng)
TESSERACT_LANG=dan+eng

# ─── Logging ──────────────────────────────────────────────────
# Log level: debug | info | warning | error
LOG_LEVEL=info
